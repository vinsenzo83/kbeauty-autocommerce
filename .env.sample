# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=kbeauty
POSTGRES_PASSWORD=kbeauty
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kbeauty

# ── PostgreSQL (CI / test override) ──────────────────────────────────────────
# When DATABASE_URL_TEST is set, app/db/session.py uses it instead of the
# POSTGRES_* components above. This ensures tests never touch production data.
# Set automatically by GitHub Actions CI; leave blank for local dev.
DATABASE_URL_TEST=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── Shopify ───────────────────────────────────────────────────────────────────
SHOPIFY_WEBHOOK_SECRET=your-shopify-webhook-secret
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# ── Sprint 2: StyleKorean supplier ────────────────────────────────────────────
STYLEKOREAN_EMAIL=
STYLEKOREAN_PASSWORD=
# Root path for bot failure artifacts (screenshots, HTML dumps)
STORAGE_PATH=./storage

# ── Sprint 3: Tracking ────────────────────────────────────────────────────────
# Interval (seconds) between tracking poll runs via Celery beat
TRACKING_POLL_INTERVAL=600

# ── Sprint 4: Best-seller crawler + Shopify product sync ─────────────────────
# Base URL for StyleKorean (change only if the domain changes)
STYLEKOREAN_BASE_URL=https://www.stylekorean.com
# Maximum number of best-seller products to crawl per run
PRODUCT_CRAWL_LIMIT=500
# Crawl interval in seconds (default: 43200 = 12 hours)
PRODUCT_CRAWL_INTERVAL=43200
# Shopify sync interval in seconds (default: 1800 = 30 minutes)
PRODUCT_SYNC_INTERVAL=1800

# ── Sprint 5: Admin Dashboard ─────────────────────────────────────────────────
# JWT signing secret — MUST be changed in production
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
# Built-in admin account (first-boot / seed); use DB users in production
ADMIN_EMAIL=admin@kbeauty.local
ADMIN_PASSWORD=admin1234
# Margin guard threshold (%): alert when calculated margin falls below this
MARGIN_GUARD_PCT=15.0
# Supplier cost ratio used for margin estimation (cost / retail)
SUPPLIER_COST_RATIO=0.75
